#!/usr/bin/env bash
# tdoc-pull — pull comments from a self-hosted octo-doc server to local
# comments.json. Pulls the FULL cross-version history (?version=all) so comments
# anchored to older versions are never dropped. Non-destructive: backs up the
# previous comments.json and merges local-only comments rather than clobbering.
#
# Usage: tdoc-pull <slug>
# Config: $TDOC_BASE_URL (env) or ~/.tdoc/config.json { base_url }
set -euo pipefail

SLUG="${1:-}"
if [ -z "$SLUG" ]; then echo "usage: tdoc-pull <slug>" >&2; exit 1; fi
command -v jq >/dev/null 2>&1 || { echo "needs jq" >&2; exit 1; }

TDOC_DIR="${TDOC_DIR:-$HOME/tdocs}"
CONFIG_FILE="$HOME/.tdoc/config.json"
BASE_URL="${TDOC_BASE_URL:-}"
if [ -z "$BASE_URL" ] && [ -f "$CONFIG_FILE" ]; then BASE_URL="$(jq -r '.base_url // empty' "$CONFIG_FILE")"; fi
if [ -z "$BASE_URL" ]; then echo "[tdoc] set TDOC_BASE_URL or run /tdoc publish first." >&2; exit 1; fi
BASE_URL="${BASE_URL%/}"

OUT="$TDOC_DIR/$SLUG/comments.json"
mkdir -p "$(dirname "$OUT")"

RAW="$(curl -sS --connect-timeout 10 --max-time 30 "$BASE_URL/v1/comments?slug=$SLUG&version=all")"
# /v1 list envelope: { "data": [...], "pagination": {...} }. Unwrap to the array,
# and normalize the wire's created_at back to the local comments.json schema
# (which uses `created`). Tolerate a bare array from older servers.
REMOTE="$(printf '%s' "$RAW" | jq -c '
  (if type == "array" then . else (.data // null) end)
  | if type == "array"
    then map(
      (if has("created_at") then .created = .created_at | del(.created_at) else . end)
      | if (.replies | type) == "array"
        then .replies |= map(if has("created_at") then .created = .created_at | del(.created_at) else . end)
        else . end)
    else null end' 2>/dev/null || true)"
if ! printf '%s' "$REMOTE" | jq -e 'type == "array"' >/dev/null 2>&1; then
  echo "tdoc-pull: server did not return a comment array (network error or bad slug?). Local file untouched." >&2
  printf '%s\n' "$RAW" | head -c 400 >&2; echo >&2
  exit 1
fi

if [ -f "$OUT" ] && jq -e 'type == "array"' "$OUT" >/dev/null 2>&1; then
  cp "$OUT" "$OUT.bak"
  MERGED="$(jq -n --argjson remote "$REMOTE" --slurpfile local "$OUT" '
    ($local[0] // []) as $loc
    | ($remote | map(.id)) as $remoteIds
    | ($loc | map(select(.id as $i | ($remoteIds | index($i)) | not))) as $localOnly
    | $remote + $localOnly')"
  printf '%s\n' "$MERGED" | jq . > "$OUT"
  LOCAL_ONLY="$(jq -n --argjson m "$MERGED" --argjson r "$REMOTE" '($m | length) - ($r | length)')"
  [ "$LOCAL_ONLY" -gt 0 ] 2>/dev/null && echo "Merged $LOCAL_ONLY local-only comment(s) (backup at $OUT.bak)."
else
  printf '%s\n' "$REMOTE" | jq . > "$OUT"
fi

echo "Pulled $(jq 'length' "$OUT") comments for $SLUG -> $OUT"
